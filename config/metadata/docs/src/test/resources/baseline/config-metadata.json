[
    {
        "module": "com.acme",
        "types": [
            {
                "type": "com.acme.AcmeServerConfig",
                "standalone": true,
                "prefix": "server",
                "description": "ACME Server configuration.",
                "inherits": [
                    "com.acme.AcmeListenerConfig"
                ],
                "options": [
                    {
                        "key": "sockets",
                        "type": "com.acme.AcmeListenerConfig",
                        "description": "Sockets",
                        "kind": "MAP"
                    },
                    {
                        "type": "com.acme.AcmeOptionsConfig",
                        "merge": true
                    }
                ]
            },
            {
                "type": "com.acme.AcmeListenerConfig",
                "description": "ACME Listener configuration",
                "options": [
                    {
                        "key": "host",
                        "description": "Listen address",
                        "defaultValue": "0.0.0.0"
                    },
                    {
                        "key": "port",
                        "type": "java.lang.Integer",
                        "description": "Listen port",
                        "defaultValue": "0"
                    }
                ]
            },
            {
                "type": "com.acme.AcmeOptionsConfig",
                "options": [
                    {
                        "key": "host",
                        "description": "Listen address",
                        "defaultValue": "localhost"
                    },
                    {
                        "key": "port",
                        "type": "java.lang.Integer",
                        "description": "Listen port",
                        "defaultValue": "8080"
                    },
                    {
                        "key": "features",
                        "type": "com.acme.AcmeFeature",
                        "description": "Dynamic features",
                        "kind": "LIST",
                        "provider": true
                    }
                ]
            },
            {
                "type": "com.acme.AcmeLoggingConfig",
                "description": "ACME Logging configuration",
                "prefix": "logging",
                "provides": [
                    "com.acme.AcmeFeature"
                ],
                "options": [
                    {
                        "key": "loggers",
                        "type": "com.acme.AcmeLoggerConfig",
                        "description": "Loggers",
                        "kind": "LIST"
                    }
                ]
            },
            {
                "type": "com.acme.AcmeLoggerConfig",
                "description": "ACME Logger configuration",
                "options": [
                    {
                        "key": "logger",
                        "description": "Logger name",
                        "experimental": true
                    },
                    {
                        "key": "level",
                        "description": "Logging level",
                        "defaultValue": "INFO",
                        "deprecated": true,
                        "allowedValues": [
                            {
                                "value": "ERROR",
                                "description": "Error level"
                            },
                            {
                                "value": "WARNING",
                                "description": "Warning level"
                            },
                            {
                                "value": "INFO",
                                "description": "Info level"
                            },
                            {
                                "value": "DEBUG",
                                "description": "Debug level"
                            }
                        ]
                    }
                ]
            },
            {
                "type": "com.acme.AcmeAuditConfig",
                "description": "ACME Audit configuration",
                "prefix": "audit",
                "provides": [
                    "com.acme.AcmeFeature"
                ],
                "options": [
                    {
                        "key": "strict",
                        "type": "java.lang.Boolean",
                        "description": "Fail on error"
                    },
                    {
                        "key": "paths",
                        "description": "Audited paths",
                        "kind": "MAP"
                    }
                ]
            },
            {
                "type": "com.acme.AcmeTracingConfig",
                "description": "ACME Tracing configuration",
                "prefix": "tracing",
                "provides": [
                    "com.acme.AcmeFeature"
                ],
                "options": [
                    {
                        "key": "host",
                        "description": "Tracing backend host",
                        "required": true
                    },
                    {
                        "key": "port",
                        "type": "java.lang.Integer",
                        "description": "Tracing backend port",
                        "defaultValue": "16686"
                    },
                    {
                        "key": "tags",
                        "description": "System tags",
                        "kind": "LIST"
                    }
                ]
            },
            {
                "type": "com.acme.AcmeBulkheadConfig",
                "standalone": true,
                "prefix": "fault-tolerance.bulkheads",
                "description": "ACME Bulkhead configuration",
                "options": [
                    {
                        "key": "limit",
                        "type": "java.lang.Integer",
                        "description": "Concurrent limit",
                        "defaultValue": "10"
                    },
                    {
                        "key": "fair",
                        "type": "java.lang.Boolean",
                        "description": "Fair queue ordering",
                        "defaultValue": "false"
                    }
                ]
            },
            {
                "type": "com.acme.AcmeSqlDataSourceConfig",
                "standalone": true,
                "prefix": "data.sources.sql",
                "description": "ACME SQL data source configuration",
                "options": [
                    {
                        "key": "url",
                        "description": "JDBC URL"
                    },
                    {
                        "key": "max-pool-size",
                        "type": "java.lang.Integer",
                        "description": "Maximum pool size",
                        "defaultValue": "20"
                    }
                ]
            },
            {
                "type": "com.acme.AcmeMetricsConfig",
                "standalone": true,
                "prefix": "metrics",
                "description": "ACME Metrics configuration",
                "options": [
                    {
                        "key": "enabled",
                        "type": "java.lang.Boolean",
                        "description": "Enable metrics",
                        "defaultValue": "true"
                    },
                    {
                        "key": "scope",
                        "description": "Metrics scope"
                    }
                ]
            },
            {
                "type": "com.acme.AcmeMetricsObserverConfig",
                "standalone": true,
                "prefix": "metrics",
                "provides": [
                    "com.acme.AcmeMetricsObserver"
                ],
                "description": "ACME Metrics observer configuration",
                "options": [
                    {
                        "key": "endpoint",
                        "description": "Observation endpoint"
                    },
                    {
                        "key": "buckets",
                        "description": "Published buckets",
                        "kind": "LIST"
                    }
                ]
            }
        ]
    }
]
